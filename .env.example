# Sanity CMS (required)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity write token (required for contact form + seed script)
# Generate at: Sanity project → API → Tokens (use "Editor" role)
SANITY_API_TOKEN=

# Sanity webhook revalidation secret
SANITY_REVALIDATE_SECRET=

# Google Maps embed key (client-side, needs domain restriction)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Google Analytics 4
NEXT_PUBLIC_GA4_ID=

# Canonical site URL for SEO
NEXT_PUBLIC_SITE_URL=https://bitancpa.co.il

# Email notifications via Resend (optional — form saves to Sanity regardless)
RESEND_API_KEY=
CONTACT_EMAIL_TO=
CONTACT_EMAIL_FROM=
